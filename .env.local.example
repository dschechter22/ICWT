# Copy this file to .env.local and fill in your own Supabase project's values.
# Find these under Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Any number works -- it just needs to match across managers/teams/matchups rows.
# Only used by the /current-season page and the roster drawer.
NEXT_PUBLIC_LEAGUE_ID=1

# Only needed if you wire up ESPN auto-sync (app/api/espn-sync/route.js).
# Leave blank if you're entering data manually.
ESPN_S2=
ESPN_SWID=
